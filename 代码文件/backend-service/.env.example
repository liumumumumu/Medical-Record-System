SERVER_PORT=8080
FRONTEND_ORIGIN=http://localhost:5173
FRONTEND_ORIGIN_ALT=http://127.0.0.1:5173
MONGODB_URI=mongodb://127.0.0.1:27017/medical_records

# Use a secret of at least 32 bytes outside the classroom demo environment.
JWT_SECRET=
JWT_EXPIRATION=2h

# mock: deterministic local results; remote: call the Flask service.
AI_MODE=remote
AI_BASE_URL=http://127.0.0.1:5000
AI_ENDPOINT=/nlp/analyze
AI_TIMEOUT=20s

UPLOAD_DIR=./data/uploads
REPORT_DIR=./data/reports

DEMO_USER_ENABLED=false
DEMO_USERNAME=demo
DEMO_PASSWORD=demo123456
SPRINGDOC_ENABLED=false
